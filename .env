# MCP Gateway - environment configuration sample
# Copy to `.env` and adjust as needed. Values here are the defaults.

GATEWAY_LISTEN=0.0.0.0
GATEWAY_PORT=5555
GATEWAY_PATH=/mcp
GATEWAY_RELOAD=true
GATEWAY_HEALTH_ENDPOINT=true
GATEWAY_METRICS=true
GATEWAY_LOG_LEVEL=info
GATEWAY_PREFIX_TOOLS=true
MCP_SERVERS_CONFIG=/app/config/mcpServers.json

# Example variables referenced from config/mcpServers.json via ${VAR} / ${VAR:-default}
FS_ROOT=/data
REMOTE_HTTP_URL=https://example.com/mcp
REMOTE_HTTP_TOKEN=changeme
REMOTE_SSE_URL=https://example.com/sse
REMOTE_WS_URL=wss://example.com/ws
